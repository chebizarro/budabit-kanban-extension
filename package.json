{
  "name": "flotilla-extension-template",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable starter template for Flotilla Smart Widgets",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @flotilla/ext-iframe dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "verify": "pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm e2e",
    "manifest:generate": "pnpm --filter @flotilla/ext-manifest generate"
  },
  "keywords": [
    "flotilla",
    "nostr",
    "smart-widget",
    "template",
    "kind-30033"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.48.2",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
